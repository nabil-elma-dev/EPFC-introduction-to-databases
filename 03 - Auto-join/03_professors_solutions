-- Q6 : 194 réponses
SELECT id_s, id_p, id_j
FROM S,P,J
WHERE s.city <> p.city
   OR p.city <> j.city;

-- ou
SELECT id_s, id_p, id_j
FROM S,P,J
WHERE NOT(s.city = p.city AND p.city = j.city);

-- Q7 : 17 réponses
SELECT DISTINCT spj1.id_p, spj2.id_p, spj1.id_s
FROM SPJ spj1, SPJ spj2
WHERE spj1.id_s = spj2.id_s
  AND spj1.id_p > spj2.id_p;

-- Q8 : 79 réponses
SELECT id_s, S.city, id_p, p.city, id_j, j.city
FROM S,P,J
WHERE s.city <> p.city
  AND s.city <> j.city
  AND p.city <> j.city;

